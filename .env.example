# Database (AWS RDS PostgreSQL)
# Serverless: use connection_limit=1 to avoid exhausting connections; optional connect_timeout.
# If using PgBouncer, use pool_mode=transaction and the same connection_limit.
DATABASE_URL="postgresql://username:password@endpoint:5432/pagerefresh?connection_limit=1&connect_timeout=10"

# AI APIs
ANTHROPIC_API_KEY="sk-ant-api03-..."
OPENAI_API_KEY="sk-..."

# AWS S3 (primary asset storage)
AWS_S3_BUCKET="pagerefresh-assets"
AWS_REGION="us-east-2"
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin (MVP: single shared secret; gate for /admin and /api/admin)
ADMIN_SECRET="your-long-random-string-min-32-chars"

# Encryption key for API keys stored in database (lib/config/encryption.ts)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_CONFIG_ENCRYPTION_KEY="your-64-char-hex-string"

# Cloud screenshot (ScreenshotOne; optional — pipeline falls back to HTML-structure analysis if unset)
# Get key at https://screenshotone.com (free tier: 100/month)
# SCREENSHOTONE_API_KEY="..."

# Rate limiting (Upstash Redis; optional — falls back to in-memory sliding window in dev)
# KV_REST_API_URL="..."
# KV_REST_API_TOKEN="..."
# Or use the Upstash names directly:
# UPSTASH_REDIS_REST_URL="..."
# UPSTASH_REDIS_REST_TOKEN="..."
